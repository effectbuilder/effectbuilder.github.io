# Turn on the Rewrite Engine
RewriteEngine On
RewriteBase /

# Dynamic component catalog JSON (PHP + Firestore REST)
RewriteRule ^builder/components-catalog\.json$ /builder/components-catalog.php [L,QSA]
RewriteRule ^builder/component-catalog-image$ /builder/component-catalog-image.php [L,QSA]
RewriteRule ^builder/component-layout\.json$ /builder/component-layout.php [L,QSA]
RewriteRule ^builder/component-layout$ /builder/component-layout.php [L,QSA]

# Desktop / Tauri — community effects (PHP + Firestore REST on `projects`)
RewriteRule ^effects-catalog\.json$ /effects-catalog.php [L,QSA]
RewriteRule ^effects/effect\.json$ /effect-json.php [L,QSA]
RewriteRule ^effects/effect-export-url\.txt$ /effect-plain-url.php [L,QSA]
RewriteRule ^effects/thumbnail\.png$ /effect-thumbnail.php [L,QSA]

# 1. Map the Custom 404 Page
ErrorDocument 404 /404.html

# 2. Redirect showcase.html to the showcase folder (with trailing slash)
# This prevents the server from guessing and ensures it finds the index file
RewriteRule ^showcase\.html$ /showcase/ [R=301,L]

# 3. Redirect gallery.html to the gallery folder
RewriteRule ^gallery\.html$ /gallery/ [R=301,L]

# 4. (Optional) Remove .html from other URLs automatically
# This helps if you moved other pages that aren't in folders
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [NC,L]

#Check cached files with the server before serving them
<FilesMatch "\.(html|htm|js|css)$">
    Header set Cache-Control "no-cache, must-revalidate"
</FilesMatch>
